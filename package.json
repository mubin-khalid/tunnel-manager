{
  "name": "ngrok-manager",
  "private": true,
  "version": "0.2.4",
  "description": "Tunnel Manager — Tauri + React desktop app for ngrok tunnels",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mubin-khalid/tunnel-manager.git"
  },
  "bugs": {
    "url": "https://github.com/mubin-khalid/tunnel-manager/issues"
  },
  "homepage": "https://github.com/mubin-khalid/tunnel-manager#readme",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/sync-version.mjs",
    "sync:repo": "node scripts/sync-repo-urls.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:all": "pnpm format && pnpm format:rust",
    "test:ts": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "pnpm test:ts && pnpm test:rust",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^0.469.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.0.4",
    "vitest": "^4.1.0"
  }
}
